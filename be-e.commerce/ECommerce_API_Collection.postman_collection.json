    {
      "name": "Mail Service",
      "item": [
        {
          "name": "Send Verification Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"name\": \"Test User\",\n  \"token\": \"verification_token_here\"\n}"
            },
            "url": {
              "raw": "http://localhost:3002/verify-email",
              "host": ["localhost"],
              "port": "3002",
              "path": ["verify-email"]
            }
          }
        },
        {
