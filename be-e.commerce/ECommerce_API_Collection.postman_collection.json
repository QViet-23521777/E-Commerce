  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set Authorization header if token exists",
          "if (pm.collectionVariables.get('jwt_token')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.collectionVariables.get('jwt_token')",
          "    });",
          "}"
        ]
      }
    }
  ]
