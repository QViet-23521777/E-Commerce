# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005
MONGODB_URI=mongodb://localhost:27017/payment

# Must match INTERNAL_SECRET in every other service / gateway .env
# Any string works locally — just keep it consistent across all services
INTERNAL_SECRET=test-secret-123

# URL of the product service (used to fetch product prices when creating a payment by items)
PRODUCT_SERVICE_URL=http://localhost:3003

# ── MoMo API endpoints (sandbox — do not change) ──────────────────────────────
MOMO_ENDPOINT=https://test-payment.momo.vn
MOMO_CREATE_PATH=/v2/gateway/api/create
MOMO_QUERY_PATH=/v2/gateway/api/query
MOMO_REFUND_PATH=/v2/gateway/api/refund

# ── MoMo sandbox credentials ──────────────────────────────────────────────────
# These are the PUBLIC test credentials from MoMo's developer sandbox.
# They work for everyone — no sign-up needed.
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz

MOMO_PARTNER_NAME=MiniSupermarket
MOMO_STORE_ID=MiniSupermarketStore

# ── Redirect & IPN URLs ───────────────────────────────────────────────────────
# MOMO_REDIRECT_URL: browser is sent here after the user finishes payment.
# Localhost is fine — MoMo just redirects the browser, it does not call this server.
MOMO_REDIRECT_URL=http://localhost:3001/payment/momo/return

# MOMO_IPN_URL: MoMo's server calls this URL to confirm payment result.
# Localhost will NOT work because MoMo cannot reach your machine.
#
# Fix: install ngrok (https://ngrok.com), then run:
#   ngrok http 3005
# Copy the https URL it gives you and set:
#   MOMO_IPN_URL=https://YOUR_ID.ngrok-free.app/api/payments/momo/ipn
#
# Without ngrok, payment status won't auto-update — use the /sync endpoint instead.
MOMO_IPN_URL=https://YOUR_NGROK_URL.ngrok-free.app/api/payments/momo/ipn

# ── Payment defaults ──────────────────────────────────────────────────────────
# requestType options: captureWallet | payWithATM | payWithCC | payWithMethod
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANG=vi
MOMO_AUTO_CAPTURE=true
